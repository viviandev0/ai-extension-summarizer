{
  "manifest_version": 3,
  "name": "AI Page Summarizer",
  "version": "1.0.0",
  "description": "Summarize any webpage instantly using AI.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Summarize this page"
  },
  "background": {
    "service_worker": "scripts/background.js"
  },
  "icons": {
    "128": "assets/icon128.png"
  }
}